+/** expo-av может вернуть объект Sound до полной готовности нативного декодера — setRateAsync/playAsync тогда дают "sound is not loaded". */
+const waitUntilSoundLoaded = async (sound, { timeoutMs = 4000, intervalMs = 40 } = {}) => {
+  if (!sound?.getStatusAsync) return false;
+  const deadline = Date.now() + timeoutMs;
+  while (Date.now() < deadline) {
+    try {
+      const status = await sound.getStatusAsync();
+      if (status?.isLoaded) return true;
+    } catch {
+      return false;
+    }
+    await new Promise((r) => setTimeout(r, intervalMs));
+  }
+  return false;
+};
